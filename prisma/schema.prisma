generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum TaskType {
  RESIZE
  GRAYSCALE
}

model Task {
  id           String     @id @default(uuid())
  status       TaskStatus @default(PENDING)
  taskType     TaskType
  params       Json?
  originalKey  String
  processedKey String?
  mimeType     String
  errorMessage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status])
}
